# TURING Project Gitignore

# ----------------------------------------------------------------------
# 1. Cryptographic Secrets & Output Files
# ----------------------------------------------------------------------
# DANGER: Never commit keys, ciphertext, or vault data
*.key
*.bin
*.hex
*.pem
*.pub
*.priv
.turing/
vaults/

# ----------------------------------------------------------------------
# 2. Rust & Maturin Build Artifacts
# ----------------------------------------------------------------------
target/
Cargo.lock

# ----------------------------------------------------------------------
# 3. Python Compiled & Cache Files
# ----------------------------------------------------------------------
__pycache__/
*.py[cod]
*~
*.so
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ----------------------------------------------------------------------
# 4. Virtual Environments
# ----------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ----------------------------------------------------------------------
# 5. Testing & Profiling
# ----------------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.pytest_cache/
htmlcov/

# ----------------------------------------------------------------------
# 6. IDEs & OS Files
# ----------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db